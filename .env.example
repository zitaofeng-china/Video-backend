# Server Configuration
PORT=6060
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/video-chat-app
# 或者使用 MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/video-chat-app?retryWrites=true&w=majority

# JWT Configuration
# ⚠️ 警告: 必须修改为强随机字符串！可以使用: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_OR_YOUR_APP_WILL_BE_INSECURE
JWT_EXPIRE=7d

# Email Configuration (使用 QQ 邮箱示例)
EMAIL_SERVICE=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-email@qq.com
EMAIL_PASS=your-email-authorization-code
EMAIL_FROM=your-email@qq.com

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000

# File Upload Configuration
MAX_FILE_SIZE=10485760
